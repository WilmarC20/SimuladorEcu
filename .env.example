# Configuración del dashboard. Copia este archivo a .env y rellena los valores.
# No subas el archivo .env al repositorio (contiene datos sensibles).

# Puerto HTTP del dashboard (por defecto 3000)
HTTP_PORT=3000

# Puerto TCP del emulador OBD2 (por defecto 35000). Apps como Torque usan este puerto.
OBD_TCP_PORT=35000

# Clave API de Google Maps (opcional). Necesaria para el Creador de rutas y mapas.
# Obtén la clave en: https://console.cloud.google.com/apis/credentials
# Activa: Maps JavaScript API y Directions API.
GOOGLE_MAPS_API_KEY=

# Map ID (opcional): para Advanced Markers. Crear en Google Cloud Console → Map Management.
GOOGLE_MAPS_MAP_ID=
